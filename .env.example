# ===========================================
# Environment Variables Template
# ===========================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control

# Environment
# Values: development, staging, production
VITE_APP_ENV=development

# ===========================================
# API Configuration
# ===========================================
# Backend API base URL (required)
# Development: http://localhost:5000/api
# Staging: https://api.staging.com/api
# Production: https://api.production.com/api
VITE_API_URL=http://localhost:5000/api

# API request timeout in milliseconds (default: 30000)
VITE_API_TIMEOUT=30000

# ===========================================
# Application Configuration
# ===========================================
# Application name displayed in the UI
VITE_APP_NAME=Portfolio Vue

# Application version (semantic versioning)
VITE_APP_VERSION=1.0.0

# ===========================================
# Feature Flags
# ===========================================
# Enable debug mode (logs, error details, etc.)
# Values: true, false
VITE_ENABLE_DEBUG=true

# Enable mock data instead of real API calls
# Values: true, false
VITE_ENABLE_MOCK_DATA=false

# ===========================================
# Authentication
# ===========================================
# LocalStorage key for authentication token
VITE_TOKEN_STORAGE_KEY=auth_token

# Token expiry time in hours
VITE_TOKEN_EXPIRY_HOURS=24
